<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- Lingkaran glow di belakang logo -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_logo_glow"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"/>

    <!-- Logo brba.png -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/brba"
        android:scaleType="centerCrop"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/viewGlow"
        app:layout_constraintBottom_toBottomOf="@id/viewGlow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nama Aplikasi -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Breaking Bad"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.05"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/viewGlow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="I am the one who knocks"
        android:textSize="13sp"
        android:textColor="#80FFFFFF"
        android:letterSpacing="0.08"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading Bar Track -->
    <View
        android:id="@+id/viewProgressTrack"
        android:layout_width="200dp"
        android:layout_height="4dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_progress_track"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading Bar Fill — animasi expand dari kiri -->
    <View
        android:id="@+id/viewProgressFill"
        android:layout_width="200dp"
        android:layout_height="4dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_progress_fill"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Teks loading -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:text="Memuat..."
        android:textSize="11sp"
        android:textColor="#60FFFFFF"
        android:alpha="0"
        app:layout_constraintBottom_toTopOf="@id/viewProgressTrack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Versi -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="v1.0.0"
        android:textSize="10sp"
        android:textColor="#40FFFFFF"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>